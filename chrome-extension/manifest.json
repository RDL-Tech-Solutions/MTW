{
  "manifest_version": 3,
  "name": "Captura de Produtos",
  "version": "2.9.26",
  "description": "Captura produtos de qualquer site e envia para a plataforma como pendente",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "clipboardRead",
    "notifications"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
